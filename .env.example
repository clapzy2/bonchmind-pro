LLM_MODE=api
API_KEY=your_openrouter_api_key_here
API_MODEL=qwen/qwen3-32b
OLLAMA_MODEL=qwen3:8b

# Database (multi-user foundation, Stage 1).
# Dev/CI default: SQLite file at ./data/app.db
# Production: set to a Postgres URL, e.g. postgresql+psycopg://user:pass@host:5432/bonchmind
DATABASE_URL=sqlite:///./data/app.db

# JWT secret (REQUIRED in production). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# In dev/tests a fallback dev key is used when this is empty.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
# Access-token lifetime in minutes. 60*24*7 = 7 days.
JWT_EXPIRE_MINUTES=10080
