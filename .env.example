# Copy to .env and fill in. The same file serves local dev and Docker; the
# defaults below are dev-friendly, the comments call out what to change for a
# Docker/production run.

# --- LLM --------------------------------------------------------------------
LLM_MODE=api
API_KEY=your_openrouter_api_key_here
API_MODEL=qwen/qwen3-32b
OLLAMA_MODEL=qwen3:8b

# --- Database ---------------------------------------------------------------
# Local dev / CI default: SQLite file at ./data/app.db
# Docker compose overrides this to Postgres automatically (see docker-compose.yml).
# To point local dev at Postgres manually:
#   DATABASE_URL=postgresql+psycopg://bonchmind:change-me@localhost:5432/bonchmind
DATABASE_URL=sqlite:///./data/app.db

# Postgres credentials used by docker-compose (the `db` service and the
# backend's DATABASE_URL are built from these). Change the password for any
# real deployment.
POSTGRES_USER=bonchmind
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bonchmind

# --- Auth -------------------------------------------------------------------
# REQUIRED in production (docker-compose refuses to start without it).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# In dev/tests an insecure fallback key is used when this is empty.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
# Access-token lifetime in minutes. 60*24*7 = 7 days.
JWT_EXPIRE_MINUTES=10080
# Set to true only when the frontend is served over HTTPS (marks the auth
# cookie Secure). Keep false for plain-HTTP localhost / docker-compose.
AUTH_COOKIE_SECURE=false

# --- Server binding ---------------------------------------------------------
# Local dev keeps loopback; the backend container sets API_HOST=0.0.0.0 itself.
API_HOST=127.0.0.1
API_PORT=8000

# --- Frontend ---------------------------------------------------------------
# Backend URL the Next server proxies /api/* to. Local dev default is
# 127.0.0.1:8000; docker-compose builds the frontend with http://backend:8000.
BONCHMIND_API_URL=http://127.0.0.1:8000
